# -- AI Core Settings --
LLM_MODEL_PATH=models/Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf
N_GPU_LAYERS=-1
N_CTX=4096
N_BATCH=512
LLM_MAX_RESPONSE_TOKENS=512
WHISPER_MODEL_SIZE=large-v3
# Where faster-whisper caches downloaded model weights. Defaults to models/whisper
# (repo-relative) if unset — uncomment to override.
# WHISPER_CACHE_DIR=models/whisper

# -- Vision (screen understanding via OpenAI API) --
ENABLE_VISION=false

# -- TTS Settings --
TTS_ENGINE=azure
# TTS_BACKEND selects azure vs fish at runtime (dashboard toggle overrides).
# Keep this 'azure' — setting it to 'fish' makes Fish the first voice on a fresh
# boot, which was a recurring bug. Switch to fish live from the dashboard instead.
TTS_BACKEND=azure
# Fish Audio TTS (pay-as-you-go alternative to Azure; selectable live via dashboard).
FISH_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# -- Azure TTS Settings -- 
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=westus3
AZURE_SPEECH_VOICE=en-US-AshleyNeural
AZURE_PROSODY_RATE=25%
AZURE_PROSODY_PITCH=+25%

# -- Bot Settings --
AI_NAME=Kira
PAUSE_THRESHOLD=0.8
VAD_AGGRESSIVENESS=3

# -- Twitch Settings --
TWITCH_OAUTH_TOKEN=
TWITCH_BOT_USERNAME=
TWITCH_CHANNEL_TO_JOIN=
TWITCH_CLIENT_ID=
BROADCASTER_ID=

# -- Web Search Settings --
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# -- Vision (OpenAI API for screen understanding) --
OPENAI_API_KEY=

# -- Storytime / Puppet Show (pre-generated shadow-puppet shows) --
# Image gen uses Google Gemini 2.5 Flash Image ("Nano-Banana") for style/character
# consistency. This is a FRESH Google AI Studio key, SEPARATE from GOOGLE_API_KEY
# (Custom Search) above. Do not reuse the Custom Search key here.
GEMINI_IMAGE_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
STORYTIME_IMAGE_PROVIDER=gemini

# -- Feature Flags --
ENABLE_TWITCH_CHAT=true
ENABLE_YOUTUBE_CHAT=true
CHAT_BATCH_WINDOW=5.0
CHAT_RESPONSE_COOLDOWN=8.0
ENABLE_CHATTER_MEMORY=true

# -- Kira types in her own chat (second expression channel; rare by design) --
# When true, Kira can emit [CHAT: message] to type a SHORT line into Twitch chat,
# so she shares the space with viewers instead of only speaking above it. YouTube
# is read-only (posting not implemented) — this is Twitch-only.
#   CHAT_POST_COOLDOWN_SEC        global transport floor shared by every poster.
#   CHAT_POST_KIRA_INTERVAL_SEC   min seconds between HER posts (on top of the floor).
#   CHAT_POST_KIRA_MAX_PER_SESSION hard ceiling per session.
ENABLE_CHAT_POSTING=true
CHAT_POST_COOLDOWN_SEC=60.0
CHAT_POST_KIRA_INTERVAL_SEC=300.0
CHAT_POST_KIRA_MAX_PER_SESSION=8

# -- Hybrid Brain (Claude Opus for deep moments) --
ANTHROPIC_API_KEY=
CLAUDE_DEEP_MODEL=claude-opus-4-7
ENABLE_CLAUDE_BRAIN=true
CLAUDE_CHAT_MODEL=claude-sonnet-4-6
ENABLE_CLAUDE_CHAT=true
ENABLE_PROMPT_CACHING=true
ENABLE_CLAUDE_STREAMING=true

# -- Inference Backend (triage / classification / fallback response) --
# Claude (Sonnet/Opus) handles main responses and is NOT affected by this.
# "groq"  -> route llama-3.1-8b-instant to Groq cloud, saves ~6-7 GB VRAM.
# "local" -> use the local llama_cpp GGUF (legacy behavior).
INFERENCE_BACKEND=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT=5.0
# Fallback when Groq fails:
#   false      -> raise (no resilience, no VRAM cost)
#   true       -> keep local Llama loaded as warm fallback (no VRAM savings)
#   lazy_load  -> load local Llama only if/when Groq fails (recommended)
GROQ_FALLBACK_TO_LOCAL=lazy_load

# -- Memory Settings --
MEMORY_PATH=memory_db/

# -- Audio Settings --
VIRTUAL_AUDIO_DEVICE=CABLE Input (VB-Audio Virtual Cable)

# -- Audio Understanding (Kira hears game/music) --
ENABLE_AUDIO_AGENT=true
AUDIO_HEARTBEAT_SECONDS=12.0
AUDIO_CLIP_SECONDS=8.0
AUDIO_MODEL=gpt-audio-mini
# AudD song-fingerprinting API token (paid; only fires on explicit song-ID intent).
AUDD_API_TOKEN=

# -- Loopback Whisper Transcriber (English ASR for stream-watching) --
# Off by default. Distil-large-v3 is English-only and produces garbage on JP/VN
# audio. Enable ONLY for English stream-watching co-watch sessions.
# For Bond-style English AAA games: set true and swap WHISPER_MODEL_SIZE to
# distil-large-v3 to free ~1.5 GB VRAM for the second Whisper instance.
ENABLE_LOOPBACK_TRANSCRIBER=false

# -- Cutscene-aware observer suppression (ACTIVITY_GAME only) --
# When true, Kira suppresses bored interjections and biases triage toward
# STAY_QUIET when vision/audio cues suggest a cutscene is playing.
# Has NO effect outside ACTIVITY_GAME mode.
CUTSCENE_AWARE=true

# -- Captions, Dashboard & Avatar --
# On-screen caption overlay (OBS browser source). Azure TTS gives word-by-word timing.
ENABLE_CAPTIONS=false
CAPTION_SERVER_PORT=8765
# Local web control panel (FastAPI, 127.0.0.1 only). Open http://127.0.0.1:8766/
CONTROL_SERVER_PORT=8766
# Mood-driven Live2D facial expressions via the VTube Studio API.
ENABLE_VTS_EXPRESSIONS=true

# -- Chess Mode (Phase 1: Kira plays Lichess vs Stockfish, on stream) --
# Requires a SEPARATE Lichess BOT account with a bot:play token, and a local
# Stockfish binary. See README "Chess Mode" for the one-time account upgrade.
# Disabled unless armed from the dashboard. CPU only.
LICHESS_BOT_TOKEN=
CHESS_ENGINE_PATH=stockfish.exe
CHESS_KIRA_ELO=1800
CHESS_MOVETIME_MS=150

# -- Auto-clip pipeline (offline, post-session) --
# Run scripts/cut_clips.py the morning after a stream: it turns Kira's
# clip-candidate artifacts into ready-to-post, pre-titled .mp4s.
# OBS_RECORDINGS_DIR is where OBS writes local recordings. Quote paths with
# spaces is NOT needed here (dotenv reads the whole line), but keep it literal.
# Output clips land in OBS_RECORDINGS_DIR/clips/YYYY-MM-DD/.
OBS_RECORDINGS_DIR=C:\Users\you\Videos
CLIP_PRE_SECONDS=8
CLIP_POST_SECONDS=22
CLIP_VIDEO_EXTS=.mkv,.mp4,.flv,.mov,.ts
